{
  "expo": {
    "name": "Fitlog",
    "slug": "fitlog",
    "scheme": "fitlog",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F4EF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Fitlog이 옷 사진을 선택하고 분석할 수 있도록 사진 접근을 허용해주세요.",
          "cameraPermission": "Fitlog이 옷 사진을 촬영하고 분석할 수 있도록 카메라 접근을 허용해주세요."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitlog.app"
    },
    "android": {
      "package": "com.fitlog.app"
    },
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:8000/api/v1"
    }
  }
}
